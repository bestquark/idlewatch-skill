# IdleWatch config — copy to ~/.idlewatch/idlewatch.env and edit as needed

# Cloud API key (get one at idlewatch.com/api)
IDLEWATCH_CLOUD_API_KEY=your-api-key-here

# Device name (shown on idlewatch.com)
IDLEWATCH_HOST=my-device-name

# How often to send metrics (ms)
IDLEWATCH_INTERVAL_MS=10000

# OpenClaw usage integration: auto|off
IDLEWATCH_OPENCLAW_USAGE=auto

# --- Developer / self-hosted only (most users can ignore below) ---

# Optional: Firebase project for self-hosted ingest
# FIREBASE_PROJECT_ID=my-firebase-project-id
# FIREBASE_SERVICE_ACCOUNT_FILE=path/to/service-account.json

# Firebase emulator (testing only)
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
