# IdleWatch config — copy this to ~/.idlewatch/idlewatch.env and edit as needed

# Device name (used on idlewatch.com)
IDLEWATCH_HOST=my-device-name

# How often to send metrics (ms). Lower = more frequent.
IDLEWATCH_INTERVAL_MS=10000

# OpenClaw usage integration: auto|off
# In 'auto': IdleWatch uses openclaw's probe/usage telemetry automatically
IDLEWATCH_OPENCLAW_USAGE=auto

# Optional: path to OpenClaw binary for packaged/non-interactive use
# IDLEWATCH_OPENCLAW_BIN=/opt/homebrew/bin/openclaw

# Optional: per-probe timeout (ms)
# IDLEWATCH_OPENCLAW_PROBE_TIMEOUT_MS=2500

# Usage freshness tuning (ms)
# IDLEWATCH_USAGE_STALE_MS=60000
# IDLEWATCH_USAGE_NEAR_STALE_MS=59500
# IDLEWATCH_USAGE_STALE_GRACE_MS=10000

# Firebase project ID (required for production telemetry)
FIREBASE_PROJECT_ID=my-firebase-project-id

# Preferred: path to service-account JSON file
# FIREBASE_SERVICE_ACCOUNT_FILE=~/Library/Application\ Support/IdleWatch/credentials/my-project-service-account.json

# Or use raw JSON inline (less secure for shell/process snapshots)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Firebase emulator mode (no credentials needed — only for testing)
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
